{
  "name": "vas3k-mcp",
  "version": "1.1.4",
  "private": true,
  "description": "Hosted remote MCP server for vas3k.club, running on Cloudflare Workers",
  "homepage": "https://github.com/uburuntu/vas3k-mcp",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.11.5",
    "hono": "^4.12.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.0.0"
    }
  }
}
